{
    "name": "tudorr89/fgo-php-api-sdk",
    "description": "PHP client for the FGO Invoicing/Billing API v7.0 — create invoices, manage articles, query nomenclatures, and more. Ships with Laravel auto-discovery.",
    "type": "library",
    "keywords": [
        "fgo",
        "invoicing",
        "billing",
        "api",
        "romania",
        "facturare",
        "e-invoice",
        "accounting",
        "laravel"
    ],
    "homepage": "https://github.com/tudorr89/fgo-php-api-sdk",
    "license": "MIT",
    "authors": [
        {
            "name": "Tudor",
            "homepage": "https://github.com/tudorr89"
        }
    ],
    "support": {
        "issues": "https://github.com/tudorr89/fgo-php-api-sdk/issues",
        "source": "https://github.com/tudorr89/fgo-php-api-sdk"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "suggest": {
        "illuminate/support": "Required to use the bundled Laravel service provider and Fgo facade (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "FgoApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FgoApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FgoApi\\Laravel\\FgoServiceProvider"
            ],
            "aliases": {
                "Fgo": "FgoApi\\Laravel\\Fgo"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
